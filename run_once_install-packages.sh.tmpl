#!/bin/bash
# OS パッケージと Homebrew 本体のブートストラップ。
# 前提: chezmoi 自身は事前に手動インストール済み (README 参照)。
# ユーザーツールは Brewfile 側で管理 (run_onchange_after_brew-bundle.sh)
set -eu

# このスクリプトが担う下地が全部揃っていれば何もしない。
# (tmux/vim/fzf/tree/gawk などは Brewfile の担当なのでここでは見ない)
all_ready() {
  command -v zsh  >/dev/null 2>&1 || return 1
  command -v brew >/dev/null 2>&1 || return 1
  [ -x "$HOME/.local/bin/anyrc" ]                          || return 1
  [ -d "$HOME/.local/opt/zplug" ]                          || return 1
  [ -d "$HOME/.cache/dein/repos/github.com/Shougo/dein.vim" ] || return 1
  return 0
}

if all_ready; then
  echo "All prerequisites already installed; skipping."
  exit 0
fi

if [ "$(whoami)" = 'root' ]; then
  sudo=''
else
  sudo='sudo'
fi

{{- if eq .chezmoi.os "linux" }}
# Linux 特有の最小限:
#   - Homebrew を動かす下地 (build-essential/curl/git/procps 相当)
#   - Homebrew では入らない Linux 特有物 (xsel, locales-all)
#   - シェル変更用 (zsh, util-linux-user)
# それ以外の CLI ツールは Brewfile 側で管理する。
if command -v apt-get >/dev/null 2>&1; then
  $sudo apt-get update
  $sudo apt-get install -y \
    build-essential procps curl file git \
    zsh xsel locales-all
elif command -v dnf >/dev/null 2>&1; then
  $sudo dnf install -y \
    gcc redhat-rpm-config curl file git procps-ng \
    zsh xsel util-linux-user
elif command -v yum >/dev/null 2>&1; then
  $sudo yum install -y \
    gcc redhat-rpm-config curl file git procps-ng \
    zsh xsel
else
  echo 'unexpected distribution' && exit 1
fi
{{- end }}

# Homebrew (macOS / Linux 共通)。Brewfile はこれに載る。
if ! command -v brew >/dev/null 2>&1; then
  $sudo /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

mkdir -p ~/.local/bin

# anyrc
if [ ! -x ~/.local/bin/anyrc ]; then
  curl -sSL https://raw.githubusercontent.com/amaya382/anyrc/master/install.sh \
    | DIR=~/.local/bin bash
fi

# zplug
export ZPLUG_HOME=~/.local/opt/zplug
if [ ! -d "${ZPLUG_HOME}" ]; then
  mkdir -p ${ZPLUG_HOME}
  curl -sL --proto-redir -all,https \
    https://raw.githubusercontent.com/zplug/installer/master/installer.zsh \
    | zsh
fi

# tpack (tmux plugin manager) は Brewfile 側で管理する。

# dein.vim
if [ ! -d ~/.cache/dein/repos/github.com/Shougo/dein.vim ]; then
  sh -c "$(curl -fsSL https://raw.githubusercontent.com/Shougo/dein-installer.vim/master/installer.sh)" -- --use-vim-config -y
fi

# デフォルトシェルを zsh に
if [ "$SHELL" != "$(command -v zsh)" ]; then
  chsh -s "$(command -v zsh)" || true
fi

echo 'OS packages installed.'
echo 'User tools will be installed by run_onchange_after_brew-bundle.sh via Brewfile.'
echo 'tmux: `prefix + I` to install plugins (via tpack)'
echo 'vim:  `:call dein#install()` to install plugins'
