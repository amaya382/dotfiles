#!/bin/bash
# ~/.tool-versions の内容が変わったときだけ mise install を走らせる
# tool-versions hash: {{ include "dot_tool-versions" | sha256sum }}
set -eu

if ! command -v mise >/dev/null 2>&1; then
  echo "mise not found; skipping. Run brew bundle first (see run_onchange_after_brew-bundle.sh)." >&2
  exit 0
fi

# ~/.tool-versions で定義されたバージョンを取り込む
mise install --yes
