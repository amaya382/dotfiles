# Homebrew Bundle
# 使い方:
#   brew bundle --global              # ~/.Brewfile をインストール
#   brew bundle --global cleanup      # Brewfile にないパッケージを列挙
#   brew bundle --global cleanup --force  # 実際にアンインストール

# ==== Taps ====
tap "amaya382/tap"

# chezmoi 自身はこのファイルを配置する時点でインストール済み前提のため含めない。
# 事前手動: brew install chezmoi

# ==== Terminal/editor stack ====
brew "tmux"           # ターミナルマルチプレクサ
brew "vim"            # エディタ
brew "fzf"            # fuzzy finder
brew "tree"           # ディレクトリ可視化
brew "gawk"           # GNU awk (macOS の BSD awk 対策)

# ==== Cross-platform tools ====
brew "gh"             # GitHub CLI
brew "jq"             # JSON プロセッサ
brew "mise"           # 言語ランタイム管理
brew "mkcert"         # ローカル TLS 証明書
brew "ripgrep"        # 高速 grep
brew "uv"             # Python パッケージマネージャ

# ==== Personal tools ====
brew "amaya382/tap/baretree"  # git worktree 拡張
brew "amaya382/tap/ftgrep"    # 日本語形態素解析付き grep

# ==== macOS only ====
brew "reattach-to-user-namespace" if OS.mac?

